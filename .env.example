SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-publishable-key
SUPABASE_SERVICE_ROLE_KEY=your-server-only-service-role-key
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

GEMINI_API_KEY=your-gemini-key
GEMINI_MODEL=gemini-3.1-flash-lite
# 32 random bytes encoded as base64. Store only in a production secret manager.
DATA_ENCRYPTION_KEY=base64-encoded-32-byte-key
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
TOOLS2_KNOWLEDGE_PATH=./tools2/output/regulations.json
TOOLS2_INTERVAL_SECONDS=3600

# Keep disabled until an API key is issued and stored as SHA-256 in radar_api_keys.
RADAR_INGEST_API_ENABLED=false
